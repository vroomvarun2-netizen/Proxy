const express = require("express");
const path = require("path");

const app = express();
const PORT = 3000;

// Serve static files
app.use(express.static(path.join(__dirname, "public")));

app.listen(PORT, () => {
    console.log(`Game portal running at http://localhost:${PORT}`);
});
